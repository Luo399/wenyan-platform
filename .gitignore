# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
.DS_Store
dist
dist-ssr
coverage
*.local

# ============================================================
# 媒体文件（大文件通过 OSS 上传，不提交到 Git）
# ============================================================
# 视频文件
public/video/
public/videos/
*.mp4
*.webm
*.mov
*.avi

# 音频文件
public/audio/
public/audios/
*.mp3
*.wav
*.ogg
*.flac

# 图片文件（大图）
public/img/
public/images/
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg
*.ico

# 保留小图标和必要图片（如 favicon）
!public/favicon.ico
!public/*.svg

# ============================================================
# 环境变量文件（包含敏感信息，不要提交）
# ============================================================
.env
.env.local
.env.development
.env.production
.env.*.local
# 忽略所有子目录下的环境变量文件
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.*.local
# 保留所有位置的模板文件
**/.env.example

# ============================================================
# 数据库文件（仅存在于服务器，不提交）
# ============================================================
*.db
*.db-journal
backend/database/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

*.tsbuildinfo

.eslintcache

# Cypress
/cypress/videos/
/cypress/screenshots/

# Vitest
__screenshots__/

# Vite
*.timestamp-*-*.mjs
