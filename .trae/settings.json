{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": {
          "tool_name": "edit_file",
          "file_paths": ["backend/server.js"]
        },
        "hooks": [
          {
            "type": "command",
            "command": "echo '后端文件已更新，如果后端服务正在运行，请手动重启。' && echo '提示：按 Ctrl+C 停止当前后端进程，然后重新运行 node backend/server.js'"
          }
        ]
      }
    ]
  }
}
