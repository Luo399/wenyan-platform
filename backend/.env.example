# ===========================
# 文言文学习平台 - 后端配置示例
# 复制为 .env 并填写真实值
# ===========================

# 服务端口
PORT=3000

# 允许跨域的前端域名（多个用逗号分隔）
CORS_ORIGIN=https://your-frontend-domain.com

# JWT 密钥（生产环境务必使用随机长字符串）
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=3600

# JSON 请求体大小限制
JSON_LIMIT=10mb

# 数据库文件路径（生产环境建议 /data/db/school.db）
DB_PATH=./database.db

# 数据文件目录（存放 students.json、answers.json）
DATA_PATH=./data

# （可选）OSS 密钥 —— 仅当后端直接读写 OSS 时才填写
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# OSS_REGION=oss-cn-hangzhou