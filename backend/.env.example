# 后端服务环境配置模板
# 复制此文件为 .env 或 .env.production 并填写实际值

# 服务器端口
PORT=3000

# CORS允许的前端域名
CORS_ORIGIN=http://localhost:5173

# JWT密钥（请使用强随机字符串，至少32位）
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=YOUR_SECRET_KEY_HERE

# JWT过期时间（秒）
JWT_EXPIRES_IN=3600

# JSON请求体大小限制
JSON_LIMIT=10mb

# 数据目录（题目数据）
DATA_BASE_PATH=./data

# ============================================================
# 数据库文件路径配置
# ============================================================
# 建议：数据库文件与代码目录分离，便于备份和管理
# 示例：
#   STUDENT_DB_PATH=/var/data/wenyan/students.db
#   ANSWER_DB_PATH=/var/data/wenyan/answer_records.db

# 学生数据库文件路径（默认：./database/students.db）
STUDENT_DB_PATH=./database/students.db

# 答题记录数据库文件路径（默认：./database/answer_records.db）
ANSWER_DB_PATH=./database/answer_records.db