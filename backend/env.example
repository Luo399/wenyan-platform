# 后端环境配置模板
# 复制此文件为 .env 并填写实际值

# 服务端口
PORT=3000

# CORS 允许的来源（逗号分隔）
# 生产环境示例：https://www.classicalab.cn,https://classicalab.cn
CORS_ORIGIN=http://localhost:5173

# HMAC 签名密钥（用于 API 鉴权）
# 生成方法：openssl rand -hex 32
# 注意：前后端必须使用相同的密钥
AUTH_SECRET=

# 生产环境配置示例
# PORT=3000
# CORS_ORIGIN=https://www.classicalab.cn,https://classicalab.cn
# AUTH_SECRET=your-256-bit-secret-key-here# 更新时间: Tue Jul 14 10:16:31 UTC 2026
