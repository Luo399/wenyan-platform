# 后端环境配置模板
# 复制此文件为 .env 并填写实际值
# 完整环境总览见 docs/environment-overview.md

# 开发环境配置
# PORT=3000
# CORS_ORIGIN=http://localhost:5173
# AUTH_SECRET=

# 测试环境配置（由 GitHub Actions 自动创建）
# PORT=3001
# CORS_ORIGIN=http://test.classicalab.cn,https://test.classicalab.cn
# AUTH_SECRET=wenyan-test-secret-2024

# 生产环境配置（由 GitHub Actions 通过 Secrets 注入）
# PORT=3000
# CORS_ORIGIN=https://www.classicalab.cn,https://classicalab.cn
# AUTH_SECRET=<从 GitHub Secrets 注入>

# 服务端口
PORT=3000

# CORS 允许的来源（逗号分隔）
CORS_ORIGIN=http://localhost:5173

# HMAC 签名密钥（用于 API 鉴权）
# 生成方法：openssl rand -hex 32
# 注意：前后端必须使用相同的密钥
AUTH_SECRET=
