{
  "text_id": "WEN_04",
  "audio_file": "WEN_04_multi_role.mp3",
  "segments": [
    {
      "sentence_index": 1,
      "time_range": "00:00-0:03",
      "role_name": "旁白📖",
      "dialogue": "庄子与惠子游于濠梁之上。"
    },
    {
      "sentence_index": 2,
      "time_range": "00:03-0:07",
      "role_name": "庄子🧓",
      "dialogue": "庄子曰：“鲦鱼出游从容，是鱼之乐也。”"
    },
    {
      "sentence_index": 3,
      "time_range": "0:07-0:10",
      "role_name": "惠子👴",
      "dialogue": "惠子曰：“子非鱼，安知鱼之乐？”"
    },
    {
      "sentence_index": 4,
      "time_range": "0:10-0:14",
      "role_name": "庄子🧓",
      "dialogue": "庄子曰：“子非我，安知我不知鱼之乐？”"
    },
    {
      "sentence_index": 5,
      "time_range": "0:14-0:21",
      "role_name": "惠子👴",
      "dialogue": "惠子曰：“我非子，固不知子矣；子固非鱼也，子之不知鱼之乐，全矣！”"
    },
    {
      "sentence_index": 6,
      "time_range": "0:21-0:29",
      "role_name": "庄子🧓",
      "dialogue": "庄子曰：“请循其本。子曰‘汝安知鱼乐’云者，既已知吾知之而问我，我知之濠上也。"
    }
  ]
}