# 开发环境配置模板
# 复制此文件为 .env.development 并填写真实值

# 后端 API 地址（开发环境使用指定的后端服务）
VITE_API_BASE=https://api.classicalab.cn

# OSS 资源基础路径（开发环境为空，使用本地相对路径）
# 开发环境下，媒体文件位于 public/ 目录，通过 Vite 静态服务提供
VITE_OSS_BASE_URL=

# ============================================================
# OSS 上传配置（用于 scripts/upload-to-oss.js）
# ============================================================
# OSS 区域，如 oss-cn-hangzhou
OSS_REGION=oss-cn-zhongwei

# 阿里云 AccessKey ID（从阿里云控制台获取，本地配置，不要提交）
OSS_ACCESS_KEY_ID=

# 阿里云 AccessKey Secret（从阿里云控制台获取，本地配置，不要提交）
OSS_ACCESS_KEY_SECRET=

# OSS Bucket 名称
OSS_BUCKET=classic-chinese

# ============================================================
# 注意：
# 1. 复制此文件为 .env.development 后填写敏感信息
# 2. .env.development 文件已被 .gitignore 排除，不会提交到仓库
# 3. 敏感信息请通过环境变量或 .env.local 文件配置
# ============================================================