# 前端环境配置模板
# 复制此文件为 .env.development 或 .env.production 并填写实际值

# 开发环境配置
# VITE_OSS_BASE_URL=http://localhost:5173
# VITE_API_BASE_URL=http://localhost:3000

# 生产环境配置
# VITE_OSS_BASE_URL=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
# VITE_API_BASE_URL=https://api.classicalab.cn

# HMAC 签名密钥（用于 API 鉴权）
# 注意：必须与后端 AUTH_SECRET 保持一致
# 生成方法：openssl rand -hex 32
VITE_AUTH_SECRET=

# 资源基础路径（OSS地址）
VITE_OSS_BASE_URL=

# 后端 API 地址
VITE_API_BASE_URL=