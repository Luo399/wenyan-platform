# 前端环境配置模板
# 复制此文件为 .env.development 或 .env.production 并填写实际值
# 完整环境总览见 docs/environment-overview.md

# 开发环境配置（参考）
# VITE_OSS_BASE_URL=http://localhost:5173
# VITE_API_BASE_URL=http://localhost:3000

# 测试环境配置（由 GitHub Actions 注入）
# VITE_OSS_BASE_URL=http://test.classicalab.cn
# VITE_API_BASE_URL=http://test-api.classicalab.cn

# 生产环境配置（由 GitHub Actions 注入）
# VITE_OSS_BASE_URL=https://classicalab.cn
# VITE_API_BASE_URL=https://api.classicalab.cn

# HMAC 签名密钥（用于 API 鉴权）
# 注意：必须与后端 AUTH_SECRET 保持一致
# 生成方法：openssl rand -hex 32
# 实际值通过 GitHub Secrets (VITE_AUTH_SECRET) 注入，不写入文件
VITE_AUTH_SECRET=

# 资源基础路径（OSS地址）
VITE_OSS_BASE_URL=

# 后端 API 地址
VITE_API_BASE_URL=
