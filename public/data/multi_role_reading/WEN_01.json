{
  "text_id": "WEN_01",
  "audio_file": "WEN_01_multi_role.mp3",
  "segments": [
    {
      "sentence_index": 1,
      "time_range": "00:00-00:16",
      "role_name": "旁白📖",
      "dialogue": "陈胜者，阳城人也，字涉。吴广者，阳夏人也，字叔。陈涉少时，尝与人佣耕，辍耕之垄上，怅恨久之，曰："
    },
    {
      "sentence_index": 2,
      "time_range": "00:16-00:19",
      "role_name": "陈胜👨🏻",
      "dialogue": "苟富贵，无相忘。"
    },
    {
      "sentence_index": 3,
      "time_range": "00:19-00:22",
      "role_name": "旁白📖",
      "dialogue": "佣者笑而应曰："
    },
    {
      "sentence_index": 4,
      "time_range": "00:22-00:26",
      "role_name": "佣者🧑🏻‍🌾",
      "dialogue": "若为佣耕，何富贵也？"
    },
    {
      "sentence_index": 5,
      "time_range": "00:26-00:29",
      "role_name": "旁白📖",
      "dialogue": "陈涉太息曰："
    },
    {
      "sentence_index": 6,
      "time_range": "00:29-00:33",
      "role_name": "陈胜👨🏻",
      "dialogue": "嗟乎！燕雀安知鸿鹄之志哉！"
    },
    {
      "sentence_index": 7,
      "time_range": "00:33-00:55",
      "role_name": "旁白📖",
      "dialogue": "二世元年七月，发闾左適戍渔阳，九百人屯大泽乡。陈胜﹑吴广皆次当行，为屯长。会天大雨，道不通，度已失期。失期，法皆斩。陈胜﹑吴广乃谋曰："
    },
    {
      "sentence_index": 8,
      "time_range": "00:55-01:00",
      "role_name": "吴广🧑🏻",
      "dialogue": "今亡亦死，举大计亦死；等死，死国可乎？"
    },
    {
      "sentence_index": 9,
      "time_range": "01:00-01:02",
      "role_name": "旁白📖",
      "dialogue": "陈胜曰："
    },
    {
      "sentence_index": 10,
      "time_range": "01:02-01:34",
      "role_name": "陈胜👨🏻",
      "dialogue": "天下苦秦久矣。吾闻二世少子也，不当立，当立者乃公子扶苏。扶苏以数谏故，上使外将兵。今或闻无罪，二世杀之。百姓多闻其贤，未知其死也。项燕为楚将，数有功，爱士卒，楚人怜之。或以为死，或以为亡。今诚以吾众诈自称公子扶苏﹑项燕，为天下唱，宜多应者。"
    },
    {
      "sentence_index": 11,
      "time_range": "01:34-01:43",
      "role_name": "旁白📖",
      "dialogue": "吴广以为然。乃行卜。卜者知其指意，曰："
    },
    {
      "sentence_index": 12,
      "time_range": "01:43-01:49",
      "role_name": "卜者🧔🏻",
      "dialogue": "足下事皆成，有功。然足下卜之鬼乎！"
    },
    {
      "sentence_index": 13,
      "time_range": "01:49-01:53",
      "role_name": "旁白📖",
      "dialogue": "陈胜﹑吴广喜，念鬼，曰："
    },
    {
      "sentence_index": 14,
      "time_range": "01:53-01:56",
      "role_name": "吴广🧑🏻",
      "dialogue": "此教我先威众耳。"
    },
    {
      "sentence_index": 15,
      "time_range": "01:56-02:15",
      "role_name": "旁白📖",
      "dialogue": "乃丹书帛曰“陈胜王\"，置人所鱼鱼腹中。卒买鱼烹食，得鱼腹中书，固以怪之矣。又间令吴广之次所旁丛祠中，夜篝火，狐鸣呼曰："
    },
    {
      "sentence_index": 16,
      "time_range": "02:12-02:15",
      "role_name": "狐狸🦊",
      "dialogue": "大楚兴，陈胜王。"
    },
    {
      "sentence_index": 17,
      "time_range": "02:15-02:21",
      "role_name": "旁白📖",
      "dialogue": "卒皆夜惊恐。旦日，卒中往往语，皆指目陈胜。"
    },
    {
      "sentence_index": 18,
      "time_range": "02:21-02:45",
      "role_name": "旁白📖",
      "dialogue": "吴广素爱人，士卒多为用者。将尉醉，广故数言欲亡，忿恚尉，令辱之，以激怒其众。尉果笞广。尉剑挺，广起，夺而杀尉。陈胜佐之，并杀两尉。召令徒属曰："
    },
    {
      "sentence_index": 19,
      "time_range": "02:45-03:00",
      "role_name": "陈胜👨🏻",
      "dialogue": "公等遇雨，皆已失期，失期当斩。藉第令毋斩，而戍死者固十六七。且壮士不死即已，死即举大名耳，王侯将相宁有种乎！"
    },
    {
      "sentence_index": 20,
      "time_range": "03:00-03:02",
      "role_name": "旁白📖",
      "dialogue": "徒属皆曰："
    },
    {
      "sentence_index": 21,
      "time_range": "03:02-03:04",
      "role_name": "众士卒🙋🏻‍♂️",
      "dialogue": "敬受命。"
    },
    {
      "sentence_index": 22,
      "time_range": "03:04-03:57",
      "role_name": "旁白📖",
      "dialogue": "乃诈称公子扶苏﹑项燕，从民欲也。袒右，称大楚。为坛而盟，祭以尉首。陈胜自立为将军，吴广为都尉。攻大泽乡，收而攻蕲。蕲下，乃令符离人葛婴将兵徇蕲以东。攻铚、酂、苦、柘、谯，皆下之。行收兵。比至陈，车六七百乘，骑千余，卒数万人。攻陈，陈守令皆不在，独守丞与战谯门中。弗胜，守丞死，乃入据陈。数日，号令召三老﹑豪杰与皆来会计事。三老﹑豪杰皆曰："
    },
    {
      "sentence_index": 23,
      "time_range": "03:57-04:05",
      "role_name": "三老、豪杰🧔🏻‍♂️",
      "dialogue": "将军身披坚执锐，伐无道，诛暴秦，复立楚国之社稷，功宜为王。"
    },
    {
      "sentence_index": 24,
      "time_range": "04:05-04:15",
      "role_name": "旁白📖",
      "dialogue": "陈涉乃立为王，号为张楚。当此时，诸郡县苦秦吏者，皆刑其长吏，杀之以应陈涉。"
    }
  ]
}
